{
  "name": "new-school-reference-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "api",
    "frontend"
  ],
  "scripts": {
    "api:install": "npm install -w api",
    "export:mysql": "npm run export:mysql -w api",
    "import:neon": "node api/scripts/import-to-neon.js",
    "dev": "concurrently \"npm run dev -w api\" \"npm run dev -w frontend\"",
    "build": "npm run build -w frontend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
